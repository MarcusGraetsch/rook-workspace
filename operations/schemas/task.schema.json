{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rook.local/schemas/task.schema.json",
  "title": "Rook Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "project_id",
    "title",
    "description",
    "status",
    "assigned_agent",
    "priority",
    "dependencies",
    "related_repo",
    "branch",
    "commits",
    "timestamps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "project_id": {
      "type": "string",
      "minLength": 2
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "backlog",
        "ready",
        "in_progress",
        "review",
        "testing",
        "blocked",
        "done"
      ]
    },
    "assigned_agent": {
      "type": "string",
      "enum": [
        "rook",
        "engineer",
        "researcher",
        "test",
        "review",
        "consultant",
        "coach",
        "health",
        "dashboard-sync"
      ]
    },
    "claimed_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_repo": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commit_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow_stage": {
      "type": "string"
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "handoff_notes": {
      "type": "string"
    },
    "last_heartbeat": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_channel": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kanban": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "board_id",
        "board_name",
        "column_id",
        "column_name",
        "task_db_id",
        "position",
        "sync_origin"
      ],
      "properties": {
        "board_id": {
          "type": "string"
        },
        "board_name": {
          "type": "string"
        },
        "column_id": {
          "type": "string"
        },
        "column_name": {
          "type": "string"
        },
        "task_db_id": {
          "type": "string"
        },
        "position": {
          "type": "integer",
          "minimum": 0
        },
        "sync_origin": {
          "type": "string",
          "enum": [
            "dashboard-kanban"
          ]
        }
      }
    },
    "github_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "sync_status"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "open",
            "closed",
            null
          ]
        },
        "sync_status": {
          "type": "string",
          "enum": [
            "not_requested",
            "pending",
            "synced",
            "error"
          ]
        },
        "last_synced_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "github_pull_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "open",
            "closed",
            "merged",
            null
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_synced_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "updated_at",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "claimed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
