        "web_fetch"
      ],
      "deny": [
        "gateway",
        "browser",
        "elevated",
        "exec"
      ]
    },
    "test": {
      "allow": [
        "read",
        "write",
        "edit",
        "exec",
        "process"
      ],
      "deny": [
        "gateway",
        "browser",
        "elevated"
      ]
    },
    "review": {
      "allow": [
        "read",
        "write",
        "edit",
        "exec",
        "process"
      ],
      "deny": [
        "gateway",
        "browser",
        "elevated"
      ]
    },
    "coach": {
      "allow": [
        "read",
        "write",
        "edit",
        "memory_search",
        "memory_get",
        "web_search",
        "web_fetch"
      ],
      "deny": [
