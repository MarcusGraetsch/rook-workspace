{
  "version": 1,
  "event_dispatcher": {
    "max_stale_minutes": 15
  },
  "agent_permission_matrix": {
    "rook": {
      "profile": "coding",
      "alsoAllow": [
        "group:messaging"
      ]
    },
    "dispatcher": {
      "profile": "messaging",
      "alsoAllow": [
        "read",
        "exec"
      ]
    },
    "engineer": {
      "allow": [
        "read",
        "write",
        "edit",
        "exec",
        "process",
        "web_search",
        "web_fetch"
      ],
      "deny": [
        "gateway",
        "browser",
        "elevated"
      ]
    },
    "researcher": {
      "allow": [
        "read",
        "write",
        "edit",
        "memory_search",
        "memory_get",
