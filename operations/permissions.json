  "violation_actions": {
    "log": "Write to /root/.openclaw/workspace/operations/rbac-violations.jsonl",
    "notify": "Send Telegram message to Marcus",
    "block": "Refuse the action (not currently enforced — policy layer only)"
  },
  "notes": [
    "This is a policy layer, not OS-level enforcement. Agents run as root. Compliance is by convention.",
    "Violations should be flagged in daily summaries and MEMORY.md.",
    "'own' means: own workspace dir, own task files (assigned_agent or claimed_by matches agent ID).",
    "secrets_read: agents may read their own API keys from agents/{id}/ but not other agents'.",
    "Review this matrix quarterly or after any security incident."
  ]
