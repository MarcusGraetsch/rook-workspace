    "description": "OpenClaw RBAC — Minimal Permission Matrix per Agent. Principle: least privilege. Each agent gets only what its domain requires.",
    "levels": {
      "none": "No access",
      "read": "Read-only access",
      "write": "Read + write access",
      "full": "Full access including admin/destructive ops",
      "own": "Access restricted to own workspace/artifacts only"
    }
  },
  "permissions": {
    "task_read": "Read canonical task JSON files",
    "task_write": "Update task fields (status, notes, handoff)",
    "task_create": "Create new canonical task JSON files",
    "task_delete": "Archive or delete task files",
    "code_read": "Read code repositories",
    "code_write": "Write to code repos (commit, push)",
    "deploy_trigger": "Trigger CI/CD pipelines or deployments",
    "github_pr": "Open/merge pull requests on GitHub",
    "message_send": "Send messages via Telegram or Discord",
    "memory_read": "Read shared memory files (MEMORY.md, wiki)",
    "memory_write": "Write or update shared memory and wiki pages",
    "secrets_read": "Read API keys, credentials, env files",
    "billing_view": "View cost and token usage data",
    "agent_spawn": "Spawn or dispatch sub-agents",
    "health_write": "Write agent health snapshots",
    "infra_write": "Modify infrastructure (K8s, DNS, cron, systemd)",
    "external_api": "Call external APIs (GitHub, Mastodon, Gmail, etc.)"
